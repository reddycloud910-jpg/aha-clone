pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'lakshmi7330'
        APP_VERSION = '1.0.1'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/reddycloud910-jpg/aha-clone.git'
            }
        }

        stage('Verify Node') {
            steps {
                // Using the official nodejs tool wrapper ensures clean plugin execution contexts
                nodejs('NodeJS-26.3.0') {
                    sh '''
                        which node || true
                        node -v || echo "Node execution failed due to system package missing"
                        npm -v || true
                    '''
                }
            }
        }

        stage('Backend Install') {
            steps {
                dir('backend') {
                    nodejs('NodeJS-26.3.0') {
                        sh 'npm ci --omit=dev'
                    }
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    nodejs('NodeJS-26.3.0') {
                        sh '''
                            npm ci
                            npm run build
                        '''
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                // Docker builds run on host environment, no Node binary required here
                sh "docker build -t ${DOCKER_HUB_USER}/netflix-frontend:${APP_VERSION} ./frontend"
                sh "docker build -t ${DOCKER_HUB_USER}/netflix-backend:${APP_VERSION} ./backend"
            }
        }
    }

    post {
        success {
            echo 'Build completed successfully'
        }
        failure {
            echo 'Build failed'
        }
    }
}
