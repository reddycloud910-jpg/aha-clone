pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'lakshmi7330'
        APP_VERSION = '1.0.1'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/reddycloud910-jpg/aha-clone.git'
            }
        }

        stage('Verify Tools') {
            steps {
                sh '''
                    node -v || true
                    npm -v || true
                    docker --version
                '''
            }
        }

        stage('Backend Install') {
            steps {
                dir('backend') {
                    sh 'npm ci --omit=dev'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    sh '''
                        npm ci
                        npm run build
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {

                dir('frontend') {
                    sh '''
                        if [ ! -f Dockerfile ]; then
                          echo "ERROR: frontend/Dockerfile missing"
                          exit 1
                        fi

                        docker build -t $DOCKER_HUB_USER/aha-frontend:$APP_VERSION .
                    '''
                }

                dir('backend') {
                    sh '''
                        if [ ! -f Dockerfile ]; then
                          echo "ERROR: backend/Dockerfile missing"
                          exit 1
                        fi

                        docker build -t $DOCKER_HUB_USER/aha-backend:$APP_VERSION .
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Build completed successfully'
        }
        failure {
            echo 'Build failed'
        }
    }
}
